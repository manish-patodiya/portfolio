# Required for /api/chat — create a key in Google AI Studio: https://aistudio.google.com/api-keys
GOOGLE_API_KEY=
GOOGLE_CHAT_MODEL=

# Optional: Gemini model id (default: gemini-2.0-flash)
# GOOGLE_CHAT_MODEL=gemini-2.0-flash

# EmailJS (contact form) — https://www.emailjs.com/
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
